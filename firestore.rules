rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to get user role (safe - returns null if document doesn't exist)
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data != null ? userDoc.data.role : null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    // Users collection
    match /users/{userId} {
      // Allow reading user profiles for email existence checks during registration
      allow read: if true;
      // Users can create their own profile during registration
      // Document ID (userId) must match the authenticated user's UID
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Listings collection
    match /listings/{listingId} {
      // Anyone can read published listings (for homepage, offers, search, etc.)
      // Hosts (and admins) can also read their own listings
      allow read: if
        // Public published listings
        (resource.data.status == 'published') ||
        // Listing owner
        (isAuthenticated() && resource.data.hostId == request.auth.uid) ||
        // Admins can read everything
        isAdmin();

      // Any authenticated user can create listings, but the hostId must match their UID
      allow create: if isAuthenticated() &&
        request.resource.data.hostId == request.auth.uid;

      // Only listing owner can update
      allow update: if isAuthenticated() &&
        resource.data.hostId == request.auth.uid;

      // Only listing owner or admin can delete
      allow delete: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Helper function to check if listing is published
    function isListingPublished(listingId) {
      let listing = get(/databases/$(database)/documents/listings/$(listingId));
      return listing != null && listing.data != null && listing.data.status == 'published';
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Allow authenticated users to read bookings
      // This enables availability checks for published listings (querying by listingId)
      // Security: Users can only read booking dates/guests, not modify. Booking creation still requires proper permissions.
      allow read: if isAuthenticated();
      // Authenticated users can create bookings
      allow create: if isAuthenticated() && 
        request.resource.data.guestId == request.auth.uid &&
        request.resource.data.hostId != request.auth.uid; // Prevent self-booking
      // Guest or host can update their bookings
      allow update: if isAuthenticated() && (
        resource.data.guestId == request.auth.uid ||
        resource.data.hostId == request.auth.uid ||
        isAdmin()
      );
      // Only admin can delete bookings
      allow delete: if isAdmin();
    }
    
    // Messages collection
    match /messages/{messageId} {
      // Users can read messages they sent or received
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      // Users can create messages where they are the sender
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
      // Users can update messages they sent
      allow update: if isAuthenticated() && 
        resource.data.senderId == request.auth.uid;
      // Users can delete messages they sent or received
      allow delete: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read published reviews
      allow read: if isAuthenticated();
      // Users can create reviews for bookings they made
      allow create: if isAuthenticated() && 
        request.resource.data.guestId == request.auth.uid;
      // Users can update their own reviews
      allow update: if isAuthenticated() && 
        resource.data.guestId == request.auth.uid;
      // Users can delete their own reviews, admins can delete any
      allow delete: if isAuthenticated() && (
        resource.data.guestId == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Wishlist collection
    match /wishlists/{wishlistId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }

    // Hosts collection
    match /hosts/{hostId} {
      // Allow reading hosts for email existence checks during registration
      allow read: if true;
      // Allow creating host profile if authenticated
      // Document ID (hostId) must match the authenticated user's UID
      allow create: if isAuthenticated() && hostId == request.auth.uid;
      allow update: if isAuthenticated() && (hostId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Allow authenticated users to read payments
      // Note: This allows queries (needed for admin dashboard) and single document reads
      // Security: Users can only read payment data, not modify. Creation/update still require proper permissions.
      allow read: if isAuthenticated();
      // Authenticated users can create payments where they are the userId (guest making payment)
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Users can update their own payments, hosts can update payments for their listings, admins can update any
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.hostId == request.auth.uid ||
        isAdmin()
      );
      // No one can delete payments (for audit trail)
      allow delete: if false;
    }
    
    // Admin collection (admin only)
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Reports collection (admin only)
    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }
    
    // Policies collection (admin can write, all authenticated can read)
    match /policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Coupons collection
    match /coupons/{couponId} {
      // Anyone authenticated can read active coupons
      allow read: if isAuthenticated() && resource.data.active == true;
      // Only admins can create/update/delete coupons
      allow write: if isAdmin();
    }
    
    // Points & Rewards collection
    match /points/{userId} {
      // Users can only read their own points
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // System can update points (handled server-side)
      allow write: if isAdmin();
    }
  }
}



